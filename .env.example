# ─── Azure OpenAI ─────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_MODEL=gpt-5.2

# ─── Azure Document Intelligence ─────────────────────────────────────────────
AZURE_DI_ENDPOINT=
AZURE_DI_KEY=
AZURE_DI_MODEL=prebuilt-layout

# ─── Azure Storage (quickformsphstor) ─────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_NAME=quickformsphstor
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER_PDF=pdf
AZURE_STORAGE_CONTAINER_PDF_PREVIEW=pdf-preview
AZURE_STORAGE_CONTAINER_IMAGE_PREVIEW=image-preview

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_USERNAME=
ADMIN_PASSWORD=
JWT_SECRET=

# ─── Form data encryption (AES-256-GCM key for data-at-rest) ─────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FORM_DATA_ENCRYPTION_KEY=

# ─── Storage backend: "azure" | "local" ──────────────────────────────────────
STORAGE_BACKEND=azure
